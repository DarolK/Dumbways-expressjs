<div class="container detail-page" style="margin-top: 120px;">
    <div class="info-section">
        <h1 class="mb-3">Project Info</h1>
        
        <div class="project-card-full">
            <h3>{{project.name}}</h3>
            <div class="author-info mb-4">
                <strong>Author ID: {{author_id}}</strong>
            </div>
            
            <div class="detail-content d-flex gap-5">
                <div class="image-section" style="flex: 1;">
                    </div>
                
                <div class="tech-section" style="flex: 1;">
                    <h3 class="mt-4 mb-3">Technologies</h3>
                    <div class="tech-list d-flex flex-wrap gap-2">
                        {{#each technologies}}
                            <span class="badge bg-dark p-2">
                                <i class="bi bi-check-circle-fill text-success"></i> {{this.name}}
                            </span>
                        {{else}}
                            <p>No technologies listed.</p>
                        {{/each}}
                    </div>
                </div>
            </div>

            <div class="description-section mt-5">
                <h3>Project Description</h3>
                <p style="white-space: pre-line;">{{project.description}}</p>
            </div>

            <div class="actions mt-5">
                <a href="/project" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>