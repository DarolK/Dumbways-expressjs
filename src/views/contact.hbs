<div class="contact-page">
    <div class="container">
        <div class="contact-content">
            <div class="contact-header">
                <h1>Contact Me</h1>
            </div>

            <div class="contact-form-container">
                {{!-- Menampilkan Pesan Sukses --}}
                {{#if success_msg}}
                <div class="alert alert-success">
                    <i class="bi bi-check-circle-fill"></i> {{success_msg}}
                </div>
                {{/if}}

                {{!-- Menampilkan Pesan Error --}}
                {{#if error_msg}}
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i> {{error_msg}}
                </div>
                {{/if}}

                <form action="/contact" method="post" class="contact-form">
                    <div class="form-group">
                        <label for="contact-name">Full Name</label>
                        <input type="text" id="contact-name" name="name" placeholder="Enter your full name" required minlength="3">
                    </div>

                    <div class="form-group">
                        <label for="contact-email">Email Address</label>
                        <input type="email" id="contact-email" name="email" placeholder="Enter your email address" required>
                    </div>

                    <div class="form-group">
                        <label for="contact-message">Message</label>
                        <textarea id="contact-message" name="message" placeholder="Write your message here..." rows="5" required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary btn-send">
                        <i class="bi bi-send"></i> Send Message
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>