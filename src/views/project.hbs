<div class="project-page container">
    
    <section class="add-project-section">
        <h1>{{#if selectedProject}}Edit Project{{else}}Add New Project{{/if}}</h1>
        
        <form action="/my-projects" method="post" class="project-form">
            {{#if selectedProject}}
                <input type="hidden" name="id" value="{{selectedProject.id}}">
            {{/if}}

            <div class="form-group">
                <label>Project Name</label>
                <input type="text" name="name" value="{{selectedProject.name}}" placeholder="Enter project name" required>
            </div>

            <div class="form-group">
                <label>Description</label>
                <textarea name="description" placeholder="Describe your project" required>{{selectedProject.description}}</textarea>
            </div>

            {{#unless selectedProject}}
            <div class="form-group">
                <label>Technologies</label>
                <div class="d-flex flex-wrap gap-3 mt-2">
                    {{#each allTechnologies}}
                    <label style="cursor:pointer; display: flex; align-items: center; gap: 8px; color: #ccc;">
                        <input type="checkbox" name="technologies" value="{{this.id}}" style="width: auto;"> {{this.name}}
                    </label>
                    {{/each}}
                </div>
            </div>
            {{/unless}}

            <div style="display: flex; gap: 15px; margin-top: 30px;">
                <button type="submit" class="btn btn-primary">
                    {{#if selectedProject}}Save Changes{{else}}Add Project{{/if}}
                </button>
                {{#if selectedProject}}
                    <a href="/project" class="btn btn-secondary">Cancel</a>
                {{/if}}
            </div>
        </form>
    </section>

    <hr style="opacity: 0.1; margin: 80px 0;">

    <section class="projects-list-section">
        <h2>My Projects</h2>
        <div class="project-list">
            {{#each projects}}
            <div class="project-item">
                <div class="project-content">
                    <h3>
                        <a href="/project-detail/{{this.id}}" class="project-link">{{this.name}}</a>
                    </h3>
                    <p class="project-description">{{this.description}}</p>
                </div>
                
                <div class="project-actions">
                    <a href="/project?id={{this.id}}" class="btn-edit-small">Edit</a>
                    <button onclick="deleteProject({{this.id}})" class="btn-delete-small">Delete</button>
                </div>
            </div>
            {{else}}
            <div class="no-projects">
                <p>No projects found. Add your first masterpiece above!</p>
            </div>
            {{/each}}
        </div>
    </section>
</div>

<script>
    async function deleteProject(id) {
        if (confirm('Are you sure you want to delete this project?')) {
            try {
                const res = await fetch(`/project/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    location.reload();
                } else {
                    alert("Failed to delete the project.");
                }
            } catch (err) {
                console.error(err);
                alert("An error occurred while deleting.");
            }
        }
    }
</script>